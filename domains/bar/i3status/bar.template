bar {
    status_command {{I3STATUS_PATH}} -c ~/.config/i3status/config
    position top
    font pango:{{FONT_FAMILY}} 10
    colors {
        background #{{BG}}
        statusline #{{FG}}
        separator  #{{MUTED}}
        focused_workspace  #{{BG}} #{{BG}} #{{FG}}
        active_workspace   #{{BG}} #{{BG}} #{{BRIGHT}}
        inactive_workspace #{{BG}} #{{BG}} #{{MUTED}}
        urgent_workspace   #{{ERROR}} #{{BG}} #{{FG}}
    }
}
