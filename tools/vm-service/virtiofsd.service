[Unit]
Description=virtiofsd for angst VM

[Service]
Type=simple
ExecStartPre=/bin/sh -c 'mkdir -p %h/.cache/angst'
ExecStart=/run/current-system/sw/bin/virtiofsd \
  --socket-path=%h/.cache/angst/vhostqemu.sock \
  --shared-dir=%h/proj/angst \
  --cache=auto \
  --sandbox=none
Restart=on-failure
RestartSec=1
ExecStopPost=/bin/sh -c 'rm -f %h/.cache/angst/vhostqemu.sock'

[Install]
WantedBy=default.target
