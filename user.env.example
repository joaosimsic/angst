# User-specific configuration for NixOS
# Copy this file to user.env and fill in your values.
# user.env is gitignored — it won't be tracked or overwritten by git pull.
#
# HOST must match one of the directories under hosts/ (personal, generic, ssh).
# Available themes: catppuccin-mocha, github, gotham, kanagawa,
#                   lotus, miasma, monochrome, noctis

HOST=personal
USERNAME=your_username
# Generate with: angst passwd
# Must be a valid sha-512 hashed password (will be read as hashedPassword)
PASSWORD=
THEME=monochrome
